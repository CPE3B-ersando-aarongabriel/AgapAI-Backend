APP_NAME=AgapAI Backend
ENVIRONMENT=production
API_PREFIX=/api

MONGO_URI=mongodb+srv://<db_user>:<db_password>@<cluster-url>/<db_name>?retryWrites=true&w=majority
MONGO_DB_NAME=<db_name>
MONGO_SERVER_SELECTION_TIMEOUT_MS=8000
STARTUP_DB_CHECK=true
STARTUP_DB_CHECK_STRICT=false

OPENAI_API_KEY=<your_openai_api_key>
OPENAI_MODEL=gpt-4.1-mini
ENABLE_AI_PRE_ANALYSIS=true

# Put your Railway frontend domain(s), comma-separated. Use * only for temporary debugging.
CORS_ORIGINS=https://<your-frontend-domain>

HOST=0.0.0.0
# Do not set PORT on Railway; it is injected automatically.
LOG_LEVEL=INFO
