APP_NAME=AgapAI Backend
ENVIRONMENT=development
API_PREFIX=/api

MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/agapai?retryWrites=true&w=majority
MONGO_DB_NAME=agapai

OPENAI_API_KEY=replace_with_your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
ENABLE_AI_PRE_ANALYSIS=true

CORS_ORIGINS=*
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
